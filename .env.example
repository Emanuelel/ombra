# Copy to .env (or .env.local) and fill in what you need. Nothing here is required to run
# `npm run dev` — the map, shade engine and time scrubber all work with zero accounts.
# See README.md "Bringing the backend online" for where to get each value.

# --- Database (Neon Postgres) ---------------------------------------------------------
# Easiest via the Vercel-Neon integration, which injects these for you. Otherwise create a
# project at https://neon.tech and paste its connection string here.
DATABASE_URL=

# --- Realtime "crown stolen" push (Ably), optional -------------------------------------
# https://ably.com — create an app, copy a root API key. Without it, steals are still saved
# to the DB, just not pushed live to the person who lost the crown.
ABLY_API_KEY=

# --- Google sign-in ----------------------------------------------------------------------
# https://console.cloud.google.com/apis/credentials — OAuth client ID (type: Web application).
# Authorized redirect URI: <your-deployed-origin>/api/auth-google-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Web push (VAPID) --------------------------------------------------------------------
# Generate a keypair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
# The client needs the public half too (must match VAPID_PUBLIC_KEY above):
VITE_VAPID_PUBLIC_KEY=

# --- Shared secrets for cron / stats endpoints --------------------------------------------
# Any random string. Vercel Cron automatically sends `Authorization: Bearer <CRON_SECRET>`
# for scheduled invocations once this is set, so /api/cron/daily-fomo can verify the caller.
CRON_SECRET=
# Gates GET /api/stats (curl -H "Authorization: Bearer $STATS_SECRET" .../api/stats).
STATS_SECRET=

# --- Client API base, optional ------------------------------------------------------------
# Leave unset for same-origin (prod, and `vercel dev`). Set only if you run the Vite dev
# server against functions deployed elsewhere, e.g. VITE_API_BASE=https://your-preview.vercel.app
VITE_API_BASE=

# --- Analytics (PostHog), optional --------------------------------------------------------
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com
